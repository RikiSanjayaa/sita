APP_NAME=SITA
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://domain-kampus.ac.id
APP_BASE_PATH=

APP_TIMEZONE=Asia/Makassar
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sita
DB_USERNAME=sita_user
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

INERTIA_SSR_ENABLED=false
INERTIA_SSR_URL=http://127.0.0.1:13714

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.kampus.ac.id
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@domain-kampus.ac.id
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=
RESEND_CA_FILE=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# Isi dengan ${APP_URL} kalau aplikasi dipasang di subpath, misalnya https://domain-kampus.ac.id/admin.
ASSET_URL=

REVERB_APP_ID=sita-production
REVERB_APP_KEY=sita-production-key
REVERB_APP_SECRET=sita-production-secret
REVERB_HOST=domain-kampus.ac.id
REVERB_PORT=8080
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
